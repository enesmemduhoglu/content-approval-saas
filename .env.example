# Postgres bağlantı string'i
DATABASE_URL=postgresql://postgres:postgres@localhost:5455/content_approval

# Migration/CLI komutları için doğrudan (pooled olmayan) bağlantı.
# Yerelde DATABASE_URL ile aynı; production'da Neon'un unpooled URL'i.
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5455/content_approval

# Google Cloud Console OAuth (boş bırakılırsa Google girişi devre dışı kalır)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# openssl rand -base64 32
AUTH_SECRET=

# Production URL (approval linklerinde kullanılır; boşsa istek origin'i kullanılır)
APP_URL=

# Vercel Blob (boş bırakılırsa yerel geliştirmede public/uploads fallback'i devreye girer)
BLOB_READ_WRITE_TOKEN=

# Resend e-posta bildirimi (boş bırakılırsa e-posta gönderimi atlanır, akış devam eder)
RESEND_API_KEY=
EMAIL_FROM=

# Upstash Redis (dağıtık rate limiting) — boşsa in-memory fallback devrede.
# Vercel Marketplace Upstash KV entegrasyonu KV_REST_API_URL / KV_REST_API_TOKEN
# adlarıyla ekler; kod her iki ad setini de tanır.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# "1" ise Google OAuth'suz test girişi (Credentials provider) aktif olur.
# YALNIZCA yerel geliştirme/test için — production'da asla set etme.
ENABLE_TEST_AUTH=
